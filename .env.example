# =============================================================================
# Autonomous Customer Support Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED]. Everything else has sensible
# defaults for local development.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI  [REQUIRED]
# -----------------------------------------------------------------------------
# Get your API key from https://platform.openai.com/api-keys
# The agent uses this to power the conversational ReAct loop.
OPENAI_API_KEY=sk-your-openai-api-key

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Async driver used by the application at runtime (asyncpg).
# If you're using the Docker Compose stack, the defaults below work out of the box.
DATABASE_URL=postgresql+asyncpg://support_agent:support_agent@localhost:5432/support_agent

# Synchronous driver used by Alembic migrations and one-off scripts.
DATABASE_URL_SYNC=postgresql://support_agent:support_agent@localhost:5432/support_agent

# -----------------------------------------------------------------------------
# Twilio SMS  (optional — the agent still works without it)
# -----------------------------------------------------------------------------
# Sign up at https://www.twilio.com/try-twilio and grab a trial number.
# These are only needed if you want the agent to send SMS notifications.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Environment: "development" enables SQLAlchemy echo logging and debug output.
# Set to "production" in deployed environments.
APP_ENV=development

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Agent Behaviour
# -----------------------------------------------------------------------------
# Which OpenAI model the ReAct agent uses. gpt-4o is recommended for tool
# calling accuracy; gpt-3.5-turbo works but may hallucinate tool arguments.
AGENT_MODEL=gpt-4o

# Temperature controls randomness. Keep low for deterministic support answers.
AGENT_TEMPERATURE=0.1

# Number of conversation messages kept in the sliding window. Older messages
# are trimmed, but extracted entities (name, email, order IDs) persist.
MEMORY_WINDOW_SIZE=20

# Refunds up to this amount (USD) are auto-approved. Anything higher gets
# flagged for manual manager review.
MAX_REFUND_AMOUNT=500.00

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
